      button: "Click Here",
      quiz: [
        { question: "Which product best suits this customer?", options: ["The Bronzer", "The Flawless Corrector", "The Primer"], correct: 0, feedback: "Correct. The Bronzer is the best placeholder answer for warmth and a natural glow." },
        { question: "What is the better application advice?", options: ["Start light and build slowly", "Apply a very heavy layer first", "Use it only under the eyes"], correct: 0, feedback: "Correct. The product is buildable, so a light-first approach is the strongest placeholder answer." },
        { question: "Which line is the best fit for the scenario?", options: ["This gives your skin a natural, sun-kissed glow.", "This is only for sharp contouring.", "This replaces loose powder."], correct: 0, feedback: "Correct. That line speaks directly to the customer’s desired outcome." },
