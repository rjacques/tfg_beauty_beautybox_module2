---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 2 | Let’s talk make up - Face</title>
  </head>
  <body class="bg-[#f4f1ed] text-[#27211c] selection:bg-[#d8c4b4] selection:text-[#241d18]">
    <main class="mx-auto max-w-[1240px] px-4 py-4 md:px-6 md:py-6">
      <header class="sticky top-3 z-30 rounded-[0.9rem] border border-[#e6dfd8] bg-white/94 px-4 py-3 shadow-[0_10px_26px_rgba(56,37,24,0.05)] backdrop-blur md:px-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="flex items-center gap-4">
            <img src={TFG_LOGO} alt="TFG logo" class="h-10 w-10" />
            <p class="text-sm font-medium text-[#51463d]">Let’s talk make up - Face</p>
          </div>
          <div class="flex flex-wrap gap-2 text-sm text-[#51463d]">
            <a href="#primer" class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">Primer</a>
            <a href="#corrector" class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">Corrector</a>
            <a href="#powder" class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">Powder</a>
            <a href="#blush" class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">Blush</a>
            <a href="#bronzer" class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">Bronzer</a>
          </div>
        </div>
      </header>

      <section class="relative mt-4 overflow-hidden rounded-[1rem] border border-[#e3ddd7] bg-[#f6f1ec] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
        <img src={courseHero.src} alt="Beauty course hero image" class="absolute inset-0 h-full w-full object-cover object-right" />
        <div class="absolute inset-0 bg-gradient-to-r from-[#f6f1ec] via-[#f6f1ec]/92 to-[#f6f1ec]/18"></div>
        <div class="relative px-6 py-10 md:px-10 md:py-14 lg:px-12 lg:py-16">
          <div class="inline-flex items-center gap-3 rounded-full border border-[#e6ddd5] bg-white/88 px-4 py-2 backdrop-blur">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[#8f7968]">Module 2</span>
          </div>
          <img src={OBC_LOGO} alt="Beauty Co. logo" class="mt-8 h-16 w-auto md:h-20" />
          <h1 class="mt-8 max-w-3xl text-4xl font-semibold tracking-[-0.03em] text-[#2f2924] md:text-6xl">Let’s talk make up - Face</h1>
          <p class="mt-4 text-xl italic text-[#665b53]">Beauty Makeup</p>
        </div>
      </section>

      <section class="mt-6 space-y-6">
        {lessons.map((lesson) => (
          <section id={lesson.id} class="overflow-hidden rounded-[1rem] border border-[#e3ddd7] bg-[#fbfaf8] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
            <div class="grid lg:grid-cols-[0.36fr_0.64fr] lg:items-end">
              <div class="px-6 py-7 md:px-8 md:py-8">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#8f7968]">{lesson.lesson}</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-[#2f2924] md:text-4xl">{lesson.title}</h2>
              </div>
              {lesson.id === 'primer' ? (
                <div class="relative overflow-hidden">
                  <img src={primerProductImage2.src} alt={`${lesson.title} banner`} class="h-[170px] w-full object-cover object-right md:h-[200px]" />
                  <div class="absolute inset-0 bg-gradient-to-r from-[#f7f2ed] via-[#f7f2ed]/90 to-transparent"></div>
                </div>
              ) : (
                <div>
                  <img src={softBanner(lesson.theme.accent, lesson.theme.soft, lesson.theme.deep)} alt={`${lesson.title} banner`} class="h-[170px] w-full object-cover md:h-[200px]" />
                </div>
              )}
            </div>

            <div class="px-6 py-7 md:px-8 md:py-8 lg:px-10">
              <div class="grid gap-4 xl:grid-cols-12">
                <aside class={`space-y-4 ${lesson.id === 'primer' ? 'xl:col-span-5' : 'xl:col-span-4'}`}>
                  <div class="rounded-[0.95rem] border border-[#e7dfd8] bg-white p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-[#8f7968]">Product</p>
                    <h3 class="mt-3 text-2xl font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(lesson.productName)}</h3>
                    {lesson.looksLike && <p class="mt-4 text-[1rem] leading-8 text-[#504841]">{lesson.looksLike}</p>}
                    {lesson.id === 'primer' ? (
                      <div class="mt-5 grid grid-cols-2 gap-3">
                        <div class="overflow-hidden rounded-[0.8rem] border border-[#ece5de] bg-[#f6f2ee]">
                          <img src={primerProductImage1.src} alt="OBC Primer product image 1" class="h-full w-full object-cover" />
                        </div>
                        <div class="overflow-hidden rounded-[0.8rem] border border-[#ece5de] bg-[#f6f2ee]">
                          <img src={primerProductImage2.src} alt="OBC Primer product image 2" class="h-full w-full object-cover" />
                        </div>
                      </div>
                    ) : (
                      <div class="mt-5 overflow-hidden rounded-[0.8rem] border border-[#ece5de] bg-[#f6f2ee]">
                        <img src={softProduct(lesson.theme.accent, lesson.theme.soft, lesson.theme.deep, lesson.visual)} alt={`${lesson.title} visual`} class="w-full object-cover" />
                      </div>
                    )}
                  </div>

                  {lesson.topTip && (
                    <div class="rounded-[0.95rem] border border-transparent p-5 text-[#2f2924]" style={`background: linear-gradient(180deg, ${lesson.theme.soft} 0%, #ffffff 100%); border-color:${lesson.theme.accent};`}>
                      <p class="text-xs uppercase tracking-[0.18em] text-[#8f7968]">Top tip</p>
                      <p class="mt-3 text-[1rem] leading-8 text-[#4e4741]">{lesson.topTip}</p>
                    </div>
                  )}
                </aside>

                <div class={`grid gap-4 md:grid-cols-2 ${lesson.id === 'primer' ? 'xl:col-span-7' : 'xl:col-span-8'}`}>
                  <article class="rounded-[0.95rem] border border-[#e7dfd8] bg-white p-5 md:col-span-2">
                    <p class="text-xs uppercase tracking-[0.18em] text-[#8f7968]">Overview</p>
                    <h3 class="mt-3 text-[1.3rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(lesson.overviewHeading)}</h3>
                    <div class="mt-4 space-y-4 text-[1rem] leading-8 text-[#4e4741]">
                      {lesson.overview.map((paragraph) => <p>{paragraph}</p>)}
                    </div>
                  </article>

                  {lesson.sections.map((section) => (
                    <article class={`rounded-[0.95rem] border border-[#e7dfd8] bg-white p-5 ${(section.subsections || (section.bullets && section.bullets.length > 4) || section.paragraph && section.paragraph.length > 150) ? 'md:col-span-2' : ''}`}>
                      {section.heading && <h3 class="text-[1.22rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(section.heading)}</h3>}
                      {section.label && !section.heading && <p class="text-[1.12rem] font-semibold text-[#2f2924]">{section.label}</p>}
                      {section.label && section.heading && <p class="mt-3 text-[1rem] text-[#4e4741]">{section.label}</p>}
                      {section.paragraph && <p class="mt-4 text-[1rem] leading-8 text-[#4e4741]">{section.paragraph}</p>}
                      {section.bullets && (
                        <ul class="mt-4 space-y-2 pl-5 text-[1rem] leading-8 text-[#4e4741] list-disc marker:text-[#605248]">
                          {section.bullets.map((item) => <li>{item}</li>)}
                        </ul>
                      )}
                      {section.subsections && (
                        <div class="mt-4 grid gap-4 md:grid-cols-2">
                          {section.subsections.map((subsection) => (
                            <div class="rounded-[0.8rem] border border-[#eee7df] bg-[#fbf8f5] p-4">
                              {subsection.label && <p class="text-[1rem] font-semibold text-[#2f2924]">{subsection.label}</p>}
                              {subsection.bullets && (
                                <ul class="mt-2 space-y-2 pl-5 text-[1rem] leading-8 text-[#4e4741] list-disc marker:text-[#605248]">
                                  {subsection.bullets.map((item) => <li>{item}</li>)}
                                </ul>
                              )}
                              {subsection.paragraph && <p class="mt-3 text-[1rem] leading-8 text-[#4e4741]">{subsection.paragraph}</p>}
                            </div>
                          ))}
                        </div>
                      )}
                    </article>
                  ))}

                  <article class="rounded-[0.95rem] border border-transparent p-5 text-white md:col-span-2" style={`background: linear-gradient(135deg, ${lesson.theme.deep} 0%, ${lesson.theme.accent} 100%);`}>
                    <div class="flex flex-wrap items-start justify-between gap-4">
                      <div class="max-w-3xl">
                        <p class="inline-flex rounded-full bg-white/18 px-4 py-2 text-sm font-semibold">{lesson.assessment.title}</p>
                        <p class="mt-4 text-[1.38rem] font-semibold leading-[1.45] tracking-[-0.02em]">{lesson.assessment.scenario}</p>
                        <p class="mt-5 text-lg font-semibold">{lesson.assessment.scene}</p>
                        <p class="mt-3 text-[1rem] leading-8 text-white/92">{lesson.assessment.customerIntro}</p>
                        <p class="mt-2 text-[1.08rem] italic leading-8 text-white/95">{lesson.assessment.customerQuote}</p>
                        <p class="mt-4 text-[1rem] leading-8 text-white/95">{lesson.assessment.goal}</p>
                        <p class="mt-4 text-[1rem] leading-8 text-white/95">Click the button below to test your knowledge.</p>
                      </div>
                    </div>

                    <details class="mt-5 overflow-hidden rounded-[0.9rem] border border-white/18 bg-white/92 text-[#2a231f] shadow-[0_10px_28px_rgba(40,27,20,0.10)]">
                      <summary class="list-none cursor-pointer px-5 py-4">
                        <span class="inline-flex rounded-full bg-[#2c241f] px-6 py-3 text-base font-semibold text-white">{lesson.assessment.button}</span>
                      </summary>

                      <div class="border-t border-[#ece4dd] px-5 py-5">
                        <div class="quiz" data-quiz>
                          <div class="flex items-center justify-between gap-4">
                            <p class="text-sm uppercase tracking-[0.18em] text-[#8f7968]">Knowledge check</p>
                            <p class="quiz-progress text-sm text-[#5b4c41]"></p>
                          </div>

                          <div class="mt-4 space-y-4">
                            {lesson.assessment.quiz.map((question, questionIndex) => (
                              <div class={`quiz-step rounded-[0.9rem] border border-[#ebe3db] bg-[#fbf8f5] p-5 ${questionIndex !== 0 ? 'hidden' : ''}`} data-step data-correct={question.correct}>
                                <p class="pr-2 text-[1.05rem] font-semibold leading-7 text-[#2f2924]">{questionIndex + 1}. {question.question}</p>
                                <div class="mt-4 space-y-3">
                                  {question.options.map((option, optionIndex) => (
                                    <label class="flex cursor-pointer gap-3 rounded-[0.8rem] border border-[#efe6df] bg-white px-4 py-3 text-sm leading-6 text-[#4d433d] transition hover:border-[#d5c3b7] hover:bg-[#fcfaf8]">
                                      <input type="radio" name={`${lesson.id}-q${questionIndex}`} value={optionIndex} class="radio radio-sm mt-1 border-[#9f866f] text-[#9f866f] checked:bg-[#9f866f] checked:text-[#9f866f]" />
                                      <span>{option}</span>
                                    </label>
                                  ))}
                                </div>
                                <p class="quiz-feedback mt-4 hidden rounded-[0.8rem] bg-[#f5efe9] px-4 py-3 text-sm leading-6 text-[#4b4039]">{question.feedback}</p>
                              </div>
                            ))}
                          </div>

                          <div class="mt-5 flex flex-wrap items-center gap-3">
                            <button type="button" class="quiz-prev btn h-auto min-h-0 rounded-full border border-[#d8cbc0] bg-white px-5 py-3 text-[#2b2420] shadow-none hover:bg-[#faf7f4]">Previous</button>
                            <button type="button" class="quiz-check btn h-auto min-h-0 rounded-full border-none bg-[#2b2420] px-5 py-3 text-white shadow-none hover:bg-black">Check this question</button>
                            <button type="button" class="quiz-next btn h-auto min-h-0 rounded-full border-none bg-[#2b2420] px-5 py-3 text-white shadow-none hover:bg-black">Next</button>
                            <button type="button" class="quiz-reset btn h-auto min-h-0 rounded-full border border-[#d8cbc0] bg-white px-5 py-3 text-[#2b2420] shadow-none hover:bg-[#faf7f4]">Reset</button>
                            <p class="quiz-result text-sm text-[#5b4c41]">Check each question to see feedback straight away.</p>
                          </div>
                        </div>
                      </div>
                    </details>
                  </article>
                </div>
              </div>
            </div>
          </section>
        ))}
      </section>
    </main>

    <script is:inline>
      const quizzes = document.querySelectorAll('[data-quiz]');

      quizzes.forEach((quiz) => {
        const steps = Array.from(quiz.querySelectorAll('[data-step]'));
        const progress = quiz.querySelector('.quiz-progress');
        const prevButton = quiz.querySelector('.quiz-prev');
        const nextButton = quiz.querySelector('.quiz-next');
        const checkButton = quiz.querySelector('.quiz-check');
        const resetButton = quiz.querySelector('.quiz-reset');
        const result = quiz.querySelector('.quiz-result');
        let current = 0;

        const cleanBaseText = (text) => {
          let value = text || '';
          if (value.startsWith('Correct.')) value = value.slice(8).trim();
          if (value.startsWith('Not quite.')) value = value.slice(10).trim();
          return value;
        };

        const updateView = () => {
          steps.forEach((step, index) => {
            step.classList.toggle('hidden', index !== current);
          });

          if (progress) {
            progress.textContent = `Question ${current + 1} of ${steps.length}`;
          }

          if (prevButton) {
            prevButton.disabled = current === 0;
            prevButton.classList.toggle('opacity-50', current === 0);
            prevButton.classList.toggle('pointer-events-none', current === 0);
          }

          if (nextButton) {
            nextButton.textContent = current === steps.length - 1 ? 'Finish review' : 'Next';
          }
        };

        const checkCurrentQuestion = () => {
          const step = steps[current];
          const selected = step.querySelector('input[type="radio"]:checked');
          const feedback = step.querySelector('.quiz-feedback');
          const correct = step.dataset.correct;

          step.classList.remove('ring-2', 'ring-[#b19a84]', 'ring-red-200');

          if (!selected) {
            if (feedback) {
              feedback.textContent = 'Select an answer first.';
              feedback.classList.remove('hidden');
            }
            if (result) {
              result.textContent = 'Select an answer first.';
            }
            return;
          }

          if (feedback && !feedback.dataset.base) {
            feedback.dataset.base = cleanBaseText(feedback.textContent);
          }

          const base = feedback ? feedback.dataset.base : '';
          const isCorrect = selected.value === correct;

          if (feedback) {
            feedback.textContent = `${isCorrect ? 'Correct.' : 'Not quite.'} ${base}`;
            feedback.classList.remove('hidden');
          }

          if (isCorrect) {
            step.classList.add('ring-2', 'ring-[#b19a84]');
            if (result) {
              result.textContent = 'Good — feedback shown. Move to the next question when you’re ready.';
            }
          } else {
            step.classList.add('ring-2', 'ring-red-200');
            if (result) {
              result.textContent = 'Feedback shown below. You can change your answer or move on.';
            }
          }
        };

        const resetQuiz = () => {
          current = 0;
          steps.forEach((step) => {
            step.querySelectorAll('input[type="radio"]').forEach((input) => {
              input.checked = false;
            });
            step.classList.remove('ring-2', 'ring-[#b19a84]', 'ring-red-200');
            const feedback = step.querySelector('.quiz-feedback');
            if (feedback) {
              feedback.textContent = feedback.dataset.base || cleanBaseText(feedback.textContent);
              feedback.classList.add('hidden');
            }
          });
          if (result) {
            result.textContent = 'Check each question to see feedback straight away.';
          }
          updateView();
        };

        checkButton?.addEventListener('click', checkCurrentQuestion);

        nextButton?.addEventListener('click', () => {
          if (current < steps.length - 1) {
            current += 1;
            updateView();
          } else if (result) {
            result.textContent = 'You have reached the end of this quiz.';
          }
        });

        prevButton?.addEventListener('click', () => {
          if (current > 0) {
            current -= 1;
            updateView();
          }
        });

        resetButton?.addEventListener('click', resetQuiz);
        updateView();
      });
    </script>
  </body>
</html>
