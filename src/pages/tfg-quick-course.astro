---
import "../styles/tfg-learning-theme.css";

const outcomes = [
  {
    label: "01",
    title: "Spot the moment",
    copy: "Notice the customer cue quickly and move before the moment is lost.",
  },
  {
    label: "02",
    title: "Lead with confidence",
    copy: "Use a short, clear line that feels premium, natural and on-brand.",
  },
  {
    label: "03",
    title: "Close the loop",
    copy: "Turn good service into the next action: fit, add-on, loyalty or follow-up.",
  },
];

const principles = [
  "Short pages with oversized type",
  "One strong idea per section",
  "Large editorial imagery, tightly cropped",
  "Cards that feel like campaign tiles, not LMS widgets",
];

const choices = [
  {
    title: "Too generic",
    body: "‘This is nice.’ Safe, but forgettable. It does not guide the customer toward a decision.",
  },
  {
    title: "Better",
    body: "‘This shape works because it gives you a cleaner silhouette and can dress up or down.’",
  },
  {
    title: "Best",
    body: "‘This is one of our easiest premium pieces to style. Let me show you two quick ways to wear it.’",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TFG Quick Course Starter</title>
  </head>

  <body>
    <main class="tfg-shell min-h-screen">
      <section class="tfg-section px-5 pb-10 pt-5 sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[1.08fr_0.92fr]">
          <div class="tfg-card flex min-h-[36rem] flex-col justify-between p-6 sm:p-8 lg:p-10">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="tfg-kicker text-[var(--tfg-purple)]">TFG quick course</p>
                <p class="mt-3 text-sm text-black/60">Premium service in 6 minutes</p>
              </div>
              <div class="rounded-full border border-black/10 bg-black px-4 py-2 text-xs font-medium tracking-[0.18em] text-white uppercase">
                3 short lessons
              </div>
            </div>

            <div class="max-w-3xl py-10 sm:py-14">
              <p class="tfg-kicker mb-5 text-black/45">Big idea</p>
              <h1 class="tfg-display text-[clamp(3.2rem,8vw,7rem)] text-black">
                Sell with
                <span class="tfg-underline text-[var(--tfg-purple)]">clarity</span>
                <br />
                not pressure.
              </h1>
              <p class="mt-8 max-w-xl text-lg leading-8 text-black/66 sm:text-xl">
                A bold, short-format learning page inspired by TFG’s clean editorial brand language,
                but adapted for fast retail learning with bigger type, simpler interactions and more energy.
              </p>
            </div>

            <div class="grid gap-4 border-t border-black/10 pt-5 sm:grid-cols-3">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-black/45">Outcome</p>
                <p class="mt-2 text-lg">Know what to say</p>
              </div>
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-black/45">Format</p>
                <p class="mt-2 text-lg">One-page microcourse</p>
              </div>
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-black/45">Style</p>
                <p class="mt-2 text-lg">Editorial + premium retail</p>
              </div>
            </div>
          </div>

          <div class="grid gap-5">
            <div class="tfg-card tfg-image-placeholder min-h-[26rem] rounded-[2rem]"></div>

            <div class="tfg-card grid gap-5 p-6 sm:grid-cols-[auto_1fr] sm:items-center sm:p-8">
              <div class="rounded-[1.5rem] bg-[var(--tfg-purple)] px-5 py-6 text-white">
                <p class="text-sm uppercase tracking-[0.22em] text-white/70">Progress</p>
                <p class="mt-4 text-6xl font-light leading-none">1</p>
                <p class="mt-3 text-sm text-white/70">of 3 sections</p>
              </div>
              <div>
                <h2 class="text-3xl font-light tracking-[-0.03em] sm:text-4xl">
                  Modern learning should look closer to a campaign page than a legacy LMS screen.
                </h2>
                <p class="mt-4 text-base leading-7 text-black/65">
                  Keep modules short, strong and visual. Use one key message, one clear action and one memorable recap.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="tfg-section px-5 py-6 sm:px-8 lg:px-10">
        <div class="mx-auto max-w-7xl">
          <div class="mb-8 flex items-end justify-between gap-4">
            <div>
              <p class="tfg-kicker text-[var(--tfg-purple)]">What learners get</p>
              <h2 class="mt-3 text-[clamp(2.2rem,5vw,4.2rem)] font-light leading-none tracking-[-0.04em]">
                Three big outcomes.
              </h2>
            </div>
            <p class="hidden max-w-md text-right text-black/55 md:block">
              These cards are deliberately oversized and sparse so the page feels premium and fast.
            </p>
          </div>

          <div class="grid gap-5 lg:grid-cols-3">
            {outcomes.map((item) => (
              <article class="tfg-card p-6 sm:p-8">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--tfg-purple)]">{item.label}</p>
                <h3 class="mt-5 text-3xl font-light tracking-[-0.03em]">{item.title}</h3>
                <p class="mt-4 text-base leading-7 text-black/65">{item.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="tfg-section px-5 py-6 sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="tfg-card tfg-panel-dark p-6 sm:p-8 lg:p-10">
            <p class="tfg-kicker text-white/60">Visual direction</p>
            <h2 class="mt-4 text-[clamp(2.3rem,4vw,4rem)] font-light leading-none tracking-[-0.04em] text-white">
              Large text.
              <br />
              Light structure.
              <br />
              Strong image blocks.
            </h2>
            <div class="my-8 h-px bg-white/10"></div>
            <div class="space-y-4">
              {principles.map((point) => (
                <div class="flex items-center gap-4">
                  <span class="h-3 w-3 rounded-full bg-[var(--tfg-gold)]"></span>
                  <p class="text-lg text-white/82">{point}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="tfg-card grid gap-6 p-6 sm:p-8 lg:grid-cols-[0.65fr_0.35fr] lg:p-10">
            <div>
              <p class="tfg-kicker text-[var(--tfg-purple)]">Recommended section pattern</p>
              <h2 class="mt-4 text-[clamp(2.3rem,4vw,4rem)] font-light leading-none tracking-[-0.04em]">
                One key idea.
                <br />
                One interaction.
                <br />
                One recap.
              </h2>
              <p class="mt-6 max-w-xl text-base leading-8 text-black/66 sm:text-lg">
                This pattern keeps fast courses consistent. It also makes AI-assisted course production much cleaner,
                because each block can map neatly to a component and a small set of props.
              </p>
            </div>

            <div class="rounded-[1.75rem] border border-black/10 bg-[var(--tfg-paper)] p-5">
              <p class="text-sm uppercase tracking-[0.22em] text-black/50">Section recipe</p>
              <div class="mt-6 space-y-3 text-lg">
                <div class="rounded-2xl border border-black/8 bg-white px-4 py-3">01 Hero statement</div>
                <div class="rounded-2xl border border-black/8 bg-white px-4 py-3">02 Key teaching point</div>
                <div class="rounded-2xl border border-black/8 bg-white px-4 py-3">03 Scenario choice</div>
                <div class="rounded-2xl border border-black/8 bg-white px-4 py-3">04 One action to try</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="tfg-section px-5 py-6 sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[1.02fr_0.98fr]">
          <div class="tfg-card p-6 sm:p-8 lg:p-10">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <p class="tfg-kicker text-[var(--tfg-purple)]">Practice block</p>
                <h2 class="mt-3 text-[clamp(2.2rem,4vw,3.8rem)] font-light leading-none tracking-[-0.04em]">
                  Match the pitch to the moment.
                </h2>
              </div>
              <div class="rounded-full bg-[var(--tfg-stone)] px-4 py-2 text-xs uppercase tracking-[0.18em] text-black/55">
                Tap or hover cards
              </div>
            </div>

            <div class="mt-8 grid gap-4 md:grid-cols-3">
              {choices.map((choice) => (
                <button class="group rounded-[1.6rem] border border-black/10 bg-white p-5 text-left transition duration-300 hover:-translate-y-1 hover:border-[var(--tfg-purple)] hover:bg-[var(--tfg-purple)] hover:text-white">
                  <p class="text-sm uppercase tracking-[0.2em] text-[var(--tfg-purple)] transition group-hover:text-white/70">Choice</p>
                  <h3 class="mt-4 text-2xl font-light tracking-[-0.03em]">{choice.title}</h3>
                  <p class="mt-4 text-sm leading-7 text-black/64 transition group-hover:text-white/82">{choice.body}</p>
                </button>
              ))}
            </div>
          </div>

          <div class="grid gap-5">
            <div class="tfg-card tfg-image-placeholder min-h-[16rem] rounded-[2rem]"></div>
            <div class="tfg-card bg-[var(--tfg-sage)]/45 p-6 sm:p-8">
              <p class="tfg-kicker text-black/55">Quick recap</p>
              <div class="mt-6 grid gap-5 sm:grid-cols-3">
                <div>
                  <p class="text-5xl font-light tracking-[-0.04em]">01</p>
                  <p class="mt-3 text-sm leading-6 text-black/64">Lead with a useful point, not a generic compliment.</p>
                </div>
                <div>
                  <p class="text-5xl font-light tracking-[-0.04em]">02</p>
                  <p class="mt-3 text-sm leading-6 text-black/64">Keep the language short enough to feel natural on the floor.</p>
                </div>
                <div>
                  <p class="text-5xl font-light tracking-[-0.04em]">03</p>
                  <p class="mt-3 text-sm leading-6 text-black/64">Move from explanation to action: style, fit, add-on, or next step.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="tfg-section px-5 pb-10 pt-6 sm:px-8 lg:px-10 lg:pb-14">
        <div class="mx-auto max-w-7xl">
          <div class="tfg-card tfg-panel-dark overflow-hidden p-6 sm:p-8 lg:p-10">
            <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
              <div>
                <p class="tfg-kicker text-white/55">Last block</p>
                <h2 class="mt-4 max-w-4xl text-[clamp(2.4rem,5vw,5rem)] font-light leading-[0.96] tracking-[-0.045em] text-white">
                  TFG learning should feel premium, fast and unmistakably retail.
                </h2>
                <p class="mt-6 max-w-2xl text-lg leading-8 text-white/72">
                  Use this starter as the base layout, swap the placeholders for approved TFG imagery, and then build reusable components for hero, outcomes, scenario cards and recap sections.
                </p>
              </div>

              <div class="flex flex-wrap gap-3 lg:justify-end">
                <a href="#" class="rounded-full bg-white px-6 py-3 text-sm font-medium uppercase tracking-[0.18em] text-black transition hover:-translate-y-0.5">
                  Start course
                </a>
                <a href="#" class="rounded-full border border-white/20 px-6 py-3 text-sm font-medium uppercase tracking-[0.18em] text-white/85 transition hover:border-white/45 hover:text-white">
                  View recap
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
